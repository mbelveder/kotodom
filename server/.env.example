# Котоши backend — скопируйте в server/.env и заполните
POLZA_API_KEY=pza_...
TG_BOT_TOKEN=1234567890:AA...   # токен от @BotFather
# Получатели уведомлений (владелец + друг), через запятую.
# Пусто = сервер сам соберёт всех, кто хоть раз написал боту.
TG_CHAT_IDS=
# Отдельный бот для алармов ATTACK (попытки промпт-инъекции в чат Смотрителя).
# Если не задан — алармы идут в основной бот выше.
TG_SECURITY_BOT_TOKEN=
TG_SECURITY_CHAT_IDS=
KD_MODEL=z-ai/glm-5.2
PORT=8787

# Hermes Agent — операционный контур (заказы и эскалации обрабатывает агент)
HERMES_URL=http://127.0.0.1:8642/v1
HERMES_KEY=aboba99999999999      # API_SERVER_KEY из ~/.hermes/.env
HERMES_OPS=1                     # 0 — выключить обработку заказов агентом
# KD_UPSTREAM=hermes             # раскомментируйте, чтобы чат Смотрителя шёл через Hermes-агента

# @koto_operations_bot — чек-лист подзадач с кнопкой подтверждения (сервер шлёт
# и слушает нажатия через long polling; токен должен совпадать с тем, что в
# skill kotoshi-operations, иначе Этап 2 будет писать в другого бота)
TG_OPS_BOT_TOKEN=
TG_OPS_CHAT_IDS=
