# КотоДом backend — скопируйте в server/.env и заполните
POLZA_API_KEY=pza_...
TG_BOT_TOKEN=1234567890:AA...   # токен от @BotFather
# Получатели уведомлений (владелец + друг), через запятую.
# Пусто = сервер сам соберёт всех, кто хоть раз написал боту.
TG_CHAT_IDS=
KD_MODEL=z-ai/glm-5.2
PORT=8787

# Hermes Agent — операционный контур (заказы и эскалации обрабатывает агент)
HERMES_URL=http://127.0.0.1:8642/v1
HERMES_KEY=aboba99999999999      # API_SERVER_KEY из ~/.hermes/.env
HERMES_OPS=1                     # 0 — выключить обработку заказов агентом
# KD_UPSTREAM=hermes             # раскомментируйте, чтобы чат Смотрителя шёл через Hermes-агента
